default_platform(:ios)

platform :ios do
  desc "Build a signed app for sideloading"
  lane :build_sideload do
    build_app(
      workspace: "ios/UFitness.xcworkspace",
      scheme: "UFitness",
      configuration: "Release",
      # This skips the failing export step
      skip_package_ipa: true, 
      # Keep these to allow the build to finish without a team
      xcargs: "CODE_SIGNING_ALLOWED=NO CODE_SIGNING_REQUIRED=NO CODE_SIGN_IDENTITY='' CODE_SIGN_ENTITLEMENTS='' GCC_OPTIMIZATION_LEVEL=0",
    )
  end
end