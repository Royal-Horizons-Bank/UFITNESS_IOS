default_platform(:ios)

platform :ios do
  desc "Build a signed IPA for sideloading"
  lane :build_sideload do
    # 1. Skip codesigning during the initial build to avoid credential errors
    build_app(
      scheme: "UFitness",
      export_method: "development",
      skip_profile_detection: true,
      export_options: {
        method: "development",
        signingStyle: "manual"
      }
    )
  end
end